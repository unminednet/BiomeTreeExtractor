{
	"schemaVersion": 1,
	"id": "biometreeextractor",
	"version": "${version}",
	"name": "Biome Tree Extractor",
	"description": "Extracts biome search tree from Minecraft to use with Cubiomes",
	"authors": [
		"Balázs Farkas (megasys)"
	],
	"contact": {
		"homepage": "https://github.com/unminednet/BiomeTreeExtractor",
		"sources": "https://github.com/unminednet/BiomeTreeExtractor",
		"issues": "https://github.com/unminednet/BiomeTreeExtractor/issues"
	},
	"license": "MIT",
	"icon": "assets/biometreeextractor/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.unmined.biometreeextractor.BiomeTreeExtractorMod"
		]
	},
	"mixins": [
		"biometreeextractor.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": ">=26.1",
		"java": ">=25",
		"fabric-api": "*"
	},
	"accessWidener": "biometreeextractor.accesswidener"
}